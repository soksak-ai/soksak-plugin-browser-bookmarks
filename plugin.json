{
  "spec": "soksak-plugin-spec@1",
  "id": "soksak-plugin-bookmarks",
  "name": "즐겨찾기",
  "version": "1.0.0",
  "repo": "https://github.com/soksak-ai/soksak-plugin-bookmarks.git",
  "description": "브라우저 즐겨찾기 목록 패널 — 클릭으로 열고 ✕ 로 제거.",
  "entry": "main.js",
  "permissions": ["ui", "commands", "commands:destructive"],
  "contributes": {
    "views": [
      {
        "id": "list",
        "title": "즐겨찾기",
        "icon": "★",
        "placements": ["sidebar-right"]
      }
    ],
    "nodes": [
      { "id": "row", "description": "즐겨찾기 행(클릭 → 열기). data-node=row/<url> (url 은 정제된 안정키)" },
      { "id": "remove", "description": "즐겨찾기 행의 ✕ 제거 버튼. data-node=remove/<url>" }
    ]
  }
}
